{
  "name": "@barrettruth/delta",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "description": "CLI client for the delta productivity platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barrettruth/delta.git"
  },
  "keywords": [
    "delta",
    "cli",
    "productivity",
    "todo",
    "task-manager"
  ],
  "bin": {
    "delta": "dist/delta.js"
  },
  "man": [
    "./man/delta.1"
  ],
  "files": [
    "dist/delta.js",
    "man/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:local": "bun build src/index.ts --compile --outfile dist/delta",
    "build:npm": "bun build src/index.ts --outfile dist/delta.js --target node && node -e \"const fs=require('fs');const f='dist/delta.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f));fs.chmodSync(f,0o755)\"",
    "build:man": "npx marked-man man/delta.1.md --version 0.1.0 --section 1 > man/delta.1",
    "prepublishOnly": "bun run build:man",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "marked-man": "^2.1.0"
  }
}
