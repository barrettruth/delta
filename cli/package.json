{
  "name": "@barrettruth/delta-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "delta": "./dist/delta"
  },
  "man": [
    "./man/delta.1"
  ],
  "scripts": {
    "build:man": "marked-man man/delta.1.md --version 0.1.0 --section 1 > man/delta.1",
    "build": "bun run build:man && bun build src/index.ts --compile --outfile dist/delta",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "marked-man": "^2.1.0"
  }
}
